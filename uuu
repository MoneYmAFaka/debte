-- Public method to toggle via code or ui
function AutoBattle:Toggle()
    local ui = state.ui
    if ui and ui.toggle then
        local newState = not ui.toggle:Get()
        ui.toggle:Set(newState)
        if newState then
            self:Start()
        else
            self:Stop()
        end
    else
        if state.running then self:Stop() else self:Start() end
    end
end

-- Update start/stop to sync UI
local oldStart = AutoBattle.Start
function AutoBattle:Start(...)
    local res = oldStart(self, ...)
    if state.ui and state.ui.toggle then
        state.ui.toggle:Set(true, true)
    end
    return res
end

local oldStop = AutoBattle.Stop
function AutoBattle:Stop()
    oldStop(self)
    if state.ui and state.ui.toggle then
        state.ui.toggle:Set(false, true)
    end
end

return AutoBattle
