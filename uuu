local function log(...)
    if AutoBattle.Debug then
        print("[AutoBattle]", ...)
    end
end

local function IsInBattle()
  local side = LocalPlayer:GetAttribute("Side")
  if not side then return false end
  -- Use our remote energy or prediction
  return GetCurrentEnergy() > 0.5
end

local function GetSide()
    local attr = LocalPlayer:GetAttribute("Side")
    if attr then
        return "Side" .. attr
    end
    local ok, s = pcall(function()
        return SharedFunctions:GetPlayerSide(LocalPlayer)
    end)
    return (ok and s) or "SideA"
end

local function GetEnemySide()
    return GetSide() == "SideA" and "SideB" or "SideA"
end

local function GetElixir()
  return GetCurrentEnergy()
end

-- Predict future elixir (uses our remote-synced rate)
local function GetElixirIn(seconds)
  return math.clamp(GetCurrentEnergy() + (energyRate or 0.357) * seconds, 0, 10)
end

local function CanAfford(name)
  return GetCurrentEnergy() >= GetCardCost(name)
end

local function Spend(name)
  -- Client prediction only. The actual spend happens server-side on successful Place.
  -- We just lower our local prediction.
  local c = GetCurrentEnergy()
  local cost = GetCardCost(name)
  if c >= cost then
    currentEnergy = c - cost   -- rough
    lastEnergySync = os.clock()
    return true
  end
  return false
end

local function GetCardRole(name)
  -- Simple fallback using our embedded data
  local meta = CARD_DATA[name]
  if meta then
    if meta.ctype == "Spell" then return "SPELL" end
    if meta.ctype == "Building" then return "BUILDING" end
    if meta.cost >= 5 then return "HEAVY" end
    return "MEDIUM"
  end
  return "MEDIUM"
end

