-- Eggs Section
local EggSection = EggsTab:CreateSection("Auto Open Eggs", false)

local eggOptions = {}
local eggIdMap = {}

local function refreshEggList()
    table.clear(eggOptions)
    table.clear(eggIdMap)
    local eggs = Library.WorldCmds.GetAllEggs()
    for _, eggInst in ipairs(eggs) do
        local id = getAttr(eggInst, "ID")
        if id then
            local dir = Library.Directory.Eggs[id]
            local label = dir and (dir.displayName or id) or id
            table.insert(eggOptions, label)
            eggIdMap[label] = id
        end
    end
end

refreshEggList()

local selectedEggLabel = eggOptions[1] or ""
local selectedEggId = eggIdMap[selectedEggLabel] or ""

EggsTab:CreateDropdown({
    Name = "Select Egg",
    Options = eggOptions,
    CurrentOption = selectedEggLabel,
    MultiSelection = false,
    Flag = "SelectedEgg",
    Callback = function(Option)
        local text = getOptionText(Option)
        selectedEggLabel = text
        selectedEggId = eggIdMap[text] or ""
    end,
})

EggsTab:CreateButton({
