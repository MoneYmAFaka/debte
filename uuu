                end

                state.ui.strategyLabel.Text = "Strategy: " .. (status.strategy or "idle")

                -- Show tower intent
                if isRunning then
                    state.ui.strategyLabel.Text = state.ui.strategyLabel.Text .. "  |  Buildings when good"
                end

                -- More info
                if status.lastCard then
                    state.ui.lastActionLabel.Text = "Last: " .. tostring(status.lastCard)
                else
                    state.ui.lastActionLabel.Text = "Last: --"
                end

                state.ui.battlefieldLabel.Text = string.format("Enemies: %d | Pressure: %.1f", status.enemies or 0, status.pressure or 0)

                state.ui.placementsLabel.Text = "Placements: " .. tostring(status.placements or 0)

                -- Current deck display update
                local deckToShow = state.deck or status.deck or {}
                if state.ui.deckStatusLabel then
                    if state.currentDeckPreset then
                        state.ui.deckStatusLabel.Text = "Current Deck: " .. state.currentDeckPreset
                    else
                        state.ui.deckStatusLabel.Text = "Current Deck: " .. (#deckToShow .. " cards")
                    end
                end
                if state.ui.currentDeckList and deckToShow and #deckToShow > 0 then
                    state.ui.currentDeckList.Text = table.concat(deckToShow, ", ")
                end
            end
            task.wait(0.35)
        end
    end)

    return state.ui
end

