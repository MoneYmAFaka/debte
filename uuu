local FarmSection = FarmingTab:CreateSection("Auto Break", false)

FarmingTab:CreateToggle({
    Name = "Auto Break",
    Info = "Sends pets to break nearby coins/crates/diamonds.",
    CurrentValue = false,
    Flag = "AutoBreak",
    Callback = function(Value)
        local on = normalizeToggleValue(Value)
        if on then
            startLoop("AutoBreak", 0.25, function()
                if not Library.WorldCmds.HasLoaded() then return end
                local coins = Library.Things:FindFirstChild("Coins")
                if not coins then return end
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end
                local myPos = root.Position
                local processed = 0
                for _, coin in ipairs(coins:GetChildren()) do
                    processed = processed + 1
                    if processed % 25 == 0 then task.wait() end
                    local pos = coin:FindFirstChild("POS")
                    if pos and (pos.Position - myPos).Magnitude <= breakRange then
                        local petsFolder = coin:FindFirstChild("Pets")
                        local hasMine = false
                        if petsFolder then
                            for _, p in ipairs(petsFolder:GetChildren()) do
                                if getAttr(p, "Owner") == LocalPlayer.Name then
                                    hasMine = true
                                    break
                                end
                            end
                        end
                        if not hasMine then
                            Library.Signal.Fire("Select Coin", coin)
                        end
                    end
                end
            end)
        else
            stopLoop("AutoBreak")
        end
    end,
})

