                            table.insert(batch, uids[i])
                        end
                        pcall(function() Library.Network.Invoke("Use Golden Machine", batch) end)
                        task.wait(0.5)
                    end
                end
            end)
        else
            stopLoop("AutoMakeGold")
        end
    end,
})

