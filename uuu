function AutoBattle:SetDeck(deck)
    if type(deck) == "table" and #deck > 0 then
        state.deck = table.clone(deck)
        log("Deck updated:", table.concat(state.deck, ", "))
    end
end

function AutoBattle:SyncDeckFromGame()
    -- Best effort from UI
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return false end
    local gameGui = pg:FindFirstChild("Game")
    if not gameGui then return end
    local deckGui = gameGui:FindFirstChild("Deck")
    if not deckGui then return end

    -- Simple scan
    local found = {}
    for _, obj in ipairs(deckGui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Text and obj.Text:len() > 1 then
            for key in pairs(CardInfo) do
                if type(key) == "string" and string.find(obj.Text, key) then
                    table.insert(found, key)
                end
            end
        end
    end

    if #found >= 4 then
        state.deck = found
        log("Synced deck from UI")
        return true
    end
    return false
end

function AutoBattle:Start(customDeck)
    if state.running then return end
    if not ensureModulesLoaded() then return end

    if customDeck then
        self:SetDeck(customDeck)
    else
        self:SyncDeckFromGame()
    end

    state.running = true
    AutoBattle.Enabled = true

    state.connection = RunService.Heartbeat:Connect(function()
        if not state.running then return end
        if os.clock() - state.lastPlaceTime > 0.15 then
            task.spawn(Think)
        end
    end)

    log("STARTED - Smart AutoBattle active")
    log("Deck:", table.concat(state.deck, ", "))
end

function AutoBattle:Stop()
    state.running = false
    AutoBattle.Enabled = false
    if state.connection then
        state.connection:Disconnect()
        state.connection = nil
    end
    log("STOPPED")
end

function AutoBattle:ForcePlace(name)
    if IsInBattle() then
        return PerformPlace(name)
    end
end

function AutoBattle:GetStatus()
    return {
        running = state.running,
        elixir = GetElixir(),
        elixirIn3s = GetElixirIn(3),
        strategy = state.currentStrategy,
        deck = state.deck,
        lastCard = state.lastCardPlaced,
        placements = state.placements,
        enemies = state.enemyCount,
        pressure = state.pressure,
    }
end

-- Equip a preset deck (Deck module loaded independently)
function AutoBattle:EquipPreset(presetName)
    local deck = ARENA_PRESETS[presetName]
    if not deck then
        warn("[AutoBattle] Unknown preset:", presetName)
        return false
    end

    -- Load ONLY the Deck module (battle modules like EnergyShared are not required for equipping)
    local ok, DeckMod = pcall(function()
        local modules = ReplicatedStorage:WaitForChild("Modules", 5)
        local uiHandler = modules and modules:WaitForChild("UIHandler", 5)
        return uiHandler and require(uiHandler:WaitForChild("Deck", 5))
    end)
    if not ok or not DeckMod or not DeckMod.SetDeck then
        warn("[AutoBattle] Could not load Deck module. Make sure you're in the game and not in a match.")
        return false
    end

    -- Extra safety: only equip if deck GUI seems ready (prevents assertions in game's deck init)
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        local gameGui = pg:FindFirstChild("Game")
        if gameGui then
            local deckGui = gameGui:FindFirstChild("Deck")
            if not deckGui then
                warn("[AutoBattle] Deck GUI not found. You probably need to open the Deck screen first (click the DECK button in lobby).")
                return false
            end
        end
    end

    -- Optional verify (only if battle modules happen to be available)
    if ensureModulesLoaded() then
        for _, cardName in ipairs(deck) do
            if not CardInfo[cardName] then
                warn("[AutoBattle] Card not found in CardInfo:", cardName)
                return false
            end
        end
    end

    -- Attempt to equip
    local success, err = pcall(function()
        DeckMod:SetDeck(deck)
    end)

    if success then
        state.deck = table.clone(deck)
        state.currentDeckPreset = presetName
        log("Equipped preset:", presetName)
        return true
    else
        warn("[AutoBattle] Failed to equip deck:", err)
        return false
    end
end

