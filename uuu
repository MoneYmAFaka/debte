local DEBUG_PREFIX = "[PSXOG Hub]"

local function consoleInfo(...)
    print(DEBUG_PREFIX, ...)
end

local function consoleWarn(...)
    warn(DEBUG_PREFIX, ...)
end

local function listChildren(inst)
    if not inst then return "<nil>" end
    local names = {}
    for _, child in ipairs(inst:GetChildren()) do
        table.insert(names, child.Name .. ":" .. child.ClassName)
    end
    return table.concat(names, ", ")
end

local function notifyStartupError(content)
    consoleWarn("Startup failed:", content)
    Rayfield:Notify({Title = "Error", Content = content, Duration = 8})
end

local function getFunctionUpvalues(fn)
    if debug and debug.getupvalues then
        local ok, values = pcall(debug.getupvalues, fn)
        if ok and type(values) == "table" then
            return values
        end
    end

    if debug and debug.getupvalue then
        local values = {}
        local index = 1
        while true do
            local ok, name, value = pcall(debug.getupvalue, fn, index)
            if not ok or name == nil then
                break
            end
            table.insert(values, value)
            index = index + 1
        end
        return values
    end

    return nil
end

local function isLikelyLibrary(value)
    if type(value) ~= "table" then
        return false
    end

    if rawget(value, "Network") and rawget(value, "WorldCmds") and rawget(value, "Things") then
        return true
    end

    return rawget(value, "Loaded") ~= nil
        and rawget(value, "ReplicatedStorage") ~= nil
        and rawget(value, "RunService") ~= nil
end

local function scanFunctionForLibrary(fn, label)
    local upvalues = getFunctionUpvalues(fn)
    if not upvalues then
        return nil
    end

    for _, upvalue in ipairs(upvalues) do
        if isLikelyLibrary(upvalue) then
            consoleInfo("Found Library through function upvalue:", label)
            return upvalue
        end
    end

    return nil
end

local function scanScriptEnvironmentsForLibrary()
    if not getsenv then
        consoleWarn("getsenv is unavailable in this executor.")
        return nil
    end

    local roots = {}
    if LocalPlayer then
        local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerScripts then table.insert(roots, playerScripts) end
        if playerGui then table.insert(roots, playerGui) end
    end

    local scriptsScanned = 0
    local functionsScanned = 0

    for _, root in ipairs(roots) do
        for _, inst in ipairs(root:GetDescendants()) do
            if inst:IsA("LocalScript") then
                scriptsScanned = scriptsScanned + 1
                local ok, env = pcall(getsenv, inst)
                if ok and type(env) == "table" then
                    if isLikelyLibrary(env.Library) then
                        consoleInfo("Found Library through script environment global:", inst:GetFullName())
                        return env.Library
                    end

                    for name, value in pairs(env) do
                        if type(value) == "function" then
                            functionsScanned = functionsScanned + 1
                            local library = scanFunctionForLibrary(value, inst:GetFullName() .. "." .. tostring(name))
                            if library then
                                return library
                            end
                        elseif isLikelyLibrary(value) then
                            consoleInfo("Found Library through script environment value:", inst:GetFullName() .. "." .. tostring(name))
                            return value
                        end
                    end
                end
            end
        end
    end

    consoleWarn("getsenv fallback found no Library. Scripts scanned:", scriptsScanned, "Functions scanned:", functionsScanned)
    return nil
end

local function getLibrary()
    consoleInfo("Starting Library lookup. PlaceId:", game.PlaceId, "IsLoaded:", game:IsLoaded())

    local replicatedStorage = game:GetService("ReplicatedStorage")
    local framework = replicatedStorage:WaitForChild("Framework", 20)
    if not framework then
        consoleWarn("ReplicatedStorage children:", listChildren(replicatedStorage))
        return nil, "ReplicatedStorage.Framework was not found."
    end
    consoleInfo("Found Framework:", framework:GetFullName())

    local libraryModule = framework:WaitForChild("Library", 20)
    if not libraryModule then
        consoleWarn("Framework children:", listChildren(framework))
        return nil, "ReplicatedStorage.Framework.Library was not found."
    end
    consoleInfo("Found Library instance:", libraryModule:GetFullName(), libraryModule.ClassName)

    if libraryModule then
        local ok, result = pcall(require, libraryModule)
        if ok and type(result) == "table" then
            consoleInfo("Required Framework.Library successfully. Loaded:", result.Loaded, "Network:", result.Network ~= nil, "WorldCmds:", result.WorldCmds ~= nil)
            return result
        end
        if not ok then
            consoleWarn("Framework.Library require failed:", result)
        else
            consoleWarn("Framework.Library returned unexpected value:", typeof(result), result)
        end
    end

    local libraryFromEnvs = scanScriptEnvironmentsForLibrary()
    if libraryFromEnvs then
        return libraryFromEnvs
    end

    if getgc then
        local scannedFunctions = 0
        local scannedUpvalues = 0
        for _, v in pairs(getgc()) do
            if type(v) == "function" then
                scannedFunctions = scannedFunctions + 1
                local ups = getFunctionUpvalues(v) or {}
                for _, up in pairs(ups) do
                    scannedUpvalues = scannedUpvalues + 1
                    if isLikelyLibrary(up) then
                        consoleInfo("Found Library through getgc fallback. Functions scanned:", scannedFunctions, "Upvalues scanned:", scannedUpvalues)
                        return up
                    end
                end
            end
        end
        consoleWarn("getgc fallback found no Library. Functions scanned:", scannedFunctions, "Upvalues scanned:", scannedUpvalues)
    else
        consoleWarn("getgc is unavailable in this executor.")
    end

    if getloadedmodules then
        local modulesScanned = 0
        for _, mod in ipairs(getloadedmodules()) do
            modulesScanned = modulesScanned + 1
            if mod.Name == "Library" then
                local ok, result = pcall(require, mod)
                if ok and type(result) == "table" and result.Network then
                    consoleInfo("Found Library through getloadedmodules fallback. Modules scanned:", modulesScanned)
                    return result
                end
                consoleWarn("getloadedmodules Library require failed or returned incomplete table:", mod:GetFullName(), ok, result)
            end
        end
        consoleWarn("getloadedmodules fallback found no usable Library. Modules scanned:", modulesScanned)
    else
        consoleWarn("getloadedmodules is unavailable in this executor.")
    end

    return nil, "Framework.Library exists, but could not be required or found in memory."
end

local Library, libraryError = getLibrary()
if not Library then
    notifyStartupError(libraryError or "Could not extract game Library. Wait for full load and retry.")
    return
end

local startedWaitingForLibrary = os.clock()
while not Library.Loaded do
    if os.clock() - startedWaitingForLibrary > 60 then
        notifyStartupError("Game Library was found but never finished loading. Join fully into PSXOG Reborn, then run the hub again.")
        return
    end
    task.wait()
end
consoleInfo("Library loaded. Network:", Library.Network ~= nil, "WorldCmds:", Library.WorldCmds ~= nil, "Things:", Library.Things ~= nil)

if not Library.Network or not Library.WorldCmds or not Library.Things then
    notifyStartupError("Game Library loaded without expected PSXOG modules.")
    return
end

local breakRange = 150

local function getOptionText(option)
    if type(option) == "table" then return option[1] or tostring(option) end
    return tostring(option)
end

local function normalizeToggleValue(value)
    if type(value) == "boolean" then return value end
    if type(value) == "table" then return value[1] == true or value[1] == "true" end
    return value == true or value == "true"
end

local loopTokens = {}
local function startLoop(name, interval, callback)
    local token = {}
    loopTokens[name] = token
    task.spawn(function()
        while loopTokens[name] == token do
            local ok, err = pcall(callback)
            if not ok then warn("[" .. name .. "]", err) end
            task.wait(interval or 0)
        end
    end)
end
local function stopLoop(name)
    loopTokens[name] = nil
end

local function getAttr(inst, name)
    if not inst then return nil end
    local attr = inst:FindFirstChild(name .. "_Attr")
    if attr then return attr.Value end
    local ok, val = pcall(function() return inst:GetAttribute(name) end)
    return ok and val or nil
end

