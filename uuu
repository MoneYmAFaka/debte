local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if not game:IsLoaded() then
    game.Loaded:Wait()
end
-- Wait an extra moment to ensure the game's LocalScripts have actually required the modules first
task.wait(3)

print("[RoDash AutoFarm] Script Execution Started...")

print("[RoDash AutoFarm] Scanning memory for ECS tables... (Bypassing require)")

local ZapClient, world, cts

local function scanMemory()
    if not getgc then return false, "Executor does not support getgc" end
    
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" then
            pcall(function()
                if rawget(v, "EcsJobAction") and rawget(v, "EcsStartAction") then
                    ZapClient = v
                end
                if rawget(v, "RoDashOrderStatus") and rawget(v, "RoDashOrderSource") then
                    cts = v
                end
                if rawget(v, "query") and rawget(v, "set") and rawget(v, "add") and rawget(v, "contains") then
                    world = v
                end
            end)
        end
        if ZapClient and world and cts then
            return true, "Found all modules!"
        end
    end
    
    return false, string.format("Missing: ZapClient(%s) world(%s) cts(%s)", tostring(ZapClient ~= nil), tostring(world ~= nil), tostring(cts ~= nil))
end

local loadSuccess, loadError = scanMemory()

if not loadSuccess or not ZapClient or not world or not cts then
    warn("[RoDash AutoFarm] CRITICAL ERROR: Failed to find game modules in memory!")
    warn("[RoDash AutoFarm] Error Details: " .. tostring(loadError))
    warn("[RoDash AutoFarm] Your executor's require is broken, and it failed to find the tables in memory as a fallback.")
    return
end

print("[RoDash AutoFarm] Modules loaded successfully! Loading UI...")

local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/UI-Interface/CustomFIeld/main/RayField.lua'))()

local Window = Rayfield:CreateWindow({
   Name = "RoDash AutoFarm",
   LoadingTitle = "RoDash Interface Suite",
   LoadingSubtitle = "AutoFarm Job",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "RoDashHub",
      FileName = "AutoFarmConfig"
   },
   Discord = {
      Enabled = false,
      Invite = "",
      RememberJoins = false
   },
   KeySystem = false
})

local Tab = Window:CreateTab("Job", 4483362458)
local Section = Tab:CreateSection("AutoFarm Control")

local autoFarmActive = false

local function getActiveOrder()
    for entityId, status in world:query(cts.RoDashOrderStatus) do
        local order = world:get(entityId, cts.RoDashOrder)
        return entityId, status, order
    end
    return nil
end

local function getAvailableOrders()
    local orders = {}
    for entityId, order in world:query(cts.RoDashOrder):without(cts.RoDashOrderStatus) do
        table.insert(orders, {id = order.id, data = order})
    end
    return orders
end

local Toggle = Tab:CreateToggle({
   Name = "Enable AutoFarm",
   Info = "Toggles the AutoFarm job on and off.",
   CurrentValue = false,
   Flag = "AutoFarmToggle",
   Callback = function(Value)
      autoFarmActive = Value
      if autoFarmActive then
         print("AutoFarm Started")
         
         -- Ensure player is on RoDash team
         if LocalPlayer.Team and LocalPlayer.Team.Name ~= "RoDash" then
             local TeamsMain = ReplicatedStorage:FindFirstChild("TeamsMain", true)
             if TeamsMain then
                 TeamsMain:InvokeServer("Join", "RoDash")
                 task.wait(1)
             end
         end

         task.spawn(function()
            while autoFarmActive do
               task.wait(1)
               
               local entityId, status, order = getActiveOrder()
               
               if status then
                   local step = status.step
                   local orderId = order.id
                   
                   local char = LocalPlayer.Character
                   local root = char and char:FindFirstChild("HumanoidRootPart")
                   
                   if step == "going_to_vendor" or step == "picking_up_bag" then
                       if root and order.storePosition then
                           root.CFrame = CFrame.new(order.storePosition)
                       end
                       task.wait(0.5)
                       
                       if step == "picking_up_bag" then
                           ZapClient.EcsJobAction.Call("pickupBag", { orderId = orderId })
                       end
                       
                   elseif step == "going_to_customer" or step == "bag_dropoff" then
                       if root and order.customerPosition then
                           root.CFrame = CFrame.new(order.customerPosition)
                       end
                       task.wait(0.5)
                       
                       ZapClient.EcsJobAction.Call("deliver", { orderId = orderId })
                       
                   elseif step == "reward_claimable" then
                       ZapClient.EcsJobAction.Call("collectReward", { orderId = orderId })

                   elseif step == "acquiring_items" then
                       -- Grocery orders not supported by this autofarm yet, cancel it to avoid getting stuck
                       ZapClient.EcsJobAction.Call("cancelOrder", { orderId = orderId })
                       task.wait(1)
                   end
               else
                   local available = getAvailableOrders()
                   local bestOrder = nil
                   
                   -- Prefer restaurant orders since groceries might require picking items
                   for _, ord in ipairs(available) do
                       if ord.data.isRestaurantPickup then
                           bestOrder = ord
                           break
                       end
                   end
                   
                   -- Fallback to any order
                   if not bestOrder and #available > 0 then
                       bestOrder = available[1]
                   end
                   
                   if bestOrder then
                       ZapClient.EcsJobAction.Call("startOrder", { orderId = bestOrder.id })
                   end
               end
            end
         end)
      else
         print("AutoFarm Stopped")
      end
   end,
})

Rayfield:LoadConfiguration()
