-- ================= SIMPLIFIED SMART PLACEMENT (no TileHandler / SharedFunctions needed) =================
local function GetSmartCFrame(cardName, isDefensive)
  local sideAttr = LocalPlayer:GetAttribute("Side") or "A"
  local isSideA = (sideAttr == "A" or sideAttr == "SideA")

  -- Approximate arena: SideA is negative Z side, SideB positive.
  -- Push direction
  local push = isSideA and -1 or 1
  local baseZ = isSideA and -25 or 25
  local defendOffset = isDefensive and (push * 15) or (push * -8)

  -- Simple lane selection
  local laneX = 0
  local r = math.random()
  if r < 0.33 then laneX = -18
  elseif r > 0.66 then laneX = 18
  end

  -- Try to find a reasonable Y
  local map = workspace:FindFirstChild("Map")
  local floor = map and map:FindFirstChild("Floor")
  local y = 3
  if floor then
    y = floor.Position.Y + (floor.Size.Y / 2) + 1.5
  end

  local pos = Vector3.new(laneX, y, baseZ + defendOffset)

  local cf = CFrame.new(pos)
  if not isSideA then
    cf = cf * CFrame.Angles(0, math.pi, 0)
  end
  return cf
end

local function PerformPlaceRemote(cardName)
  local pr = getPlaceRemote()
  if not pr then
    warn("[AutoBattle] Place remote not found")
    return false
  end
  local ctype = GetCardType(cardName)
  local cf = GetSmartCFrame(cardName, false)  -- can improve with pressure later
  pr:FireServer(ctype, cardName, cf)
  return true
end

