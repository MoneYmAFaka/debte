-- ================= REMOTE-BASED ENERGY (no module required) =================
local currentEnergy = 5
local energyRate = 0.357
local lastEnergySync = os.clock()
local energyInitialized = false

local function hookEnergyRemote()
  local success = pcall(function()
    local remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
    local energyRemote = remotes:WaitForChild("Energy", 5)
    energyRemote.OnClientEvent:Connect(function(action, data)
      if action == "Initialize" then
        currentEnergy = 5
        energyRate = (data and data.EnergyRate) or 0.357
        lastEnergySync = os.clock()
        energyInitialized = true
      elseif action == "RateChange" then
        energyRate = data or energyRate
      elseif action == "SyncCheck" then
        currentEnergy = data or currentEnergy
        lastEnergySync = os.clock()
      end
    end)
  end)
  if not success then
    warn("[AutoBattle] Could not hook Energy remote, will use prediction only.")
  end
end

hookEnergyRemote()

local function GetCurrentEnergy()
  if not energyInitialized then
    -- fallback prediction from starting 5
    local elapsed = os.clock() - lastEnergySync
    return math.clamp(5 + elapsed * energyRate, 0, 10)
  end
  local elapsed = os.clock() - lastEnergySync
  return math.clamp(currentEnergy + elapsed * energyRate, 0, 10)
end

