PetsTab:CreateToggle({
    SectionParent = GoldSection,
    Name = "Auto Make Gold",
    Info = "Converts eligible normal pets to Golden.",
    CurrentValue = false,
    Flag = "AutoMakeGold",
    Callback = function(Value)
        local on = normalizeToggleValue(Value)
        if on then
            startLoop("AutoMakeGold", 1.5, function()
                if not Library.WorldCmds.HasLoaded() then return end
                if Library.Variables.UsingMachine then return end
                local save = Library.Save.Get()
                if not save then return end
                local pets = save.Pets
                if not pets then return end
                local groups = {}
                for _, pet in ipairs(pets) do
                    local dir = Library.Directory.Pets[tostring(pet.id)]
                    if dir and not dir.isPremium and not pet.g and not pet.r and not pet.dm and dir.rarity ~= "Exclusive" then
                        groups[pet.id] = groups[pet.id] or {}
                        table.insert(groups[pet.id], tostring(pet.uid))
                    end
                end
                local ok, machineInfo = pcall(function() return Library.Network.Invoke("Get Golden Machine Info") end)
                local maxBatch = (ok and type(machineInfo) == "table") and #machineInfo or 3
                for petId, uids in pairs(groups) do
                    if loopTokens["AutoMakeGold"] == nil then break end
                    if #uids >= 2 then
