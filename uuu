local function CreateModernToggle(parent, onToggle)
    -- The switch container
    local switch = Instance.new("Frame")
    switch.Name = "ToggleSwitch"
    switch.Size = UDim2.new(0, 48, 0, 26)
    switch.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    switch.BorderSizePixel = 0
    switch.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = switch

    -- The moving knob
    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0, 3, 0.5, 0)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.fromRGB(240, 240, 245)
    knob.BorderSizePixel = 0
    knob.Parent = switch

    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob

    local isOn = false

    local function updateVisual(animate)
        local targetPos = isOn and UDim2.new(1, -23, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        local targetColor = isOn and Color3.fromRGB(0, 210, 160) or Color3.fromRGB(60, 60, 75)

        if animate then
            TweenService:Create(switch, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                BackgroundColor3 = targetColor
            }):Play()
            TweenService:Create(knob, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                Position = targetPos
            }):Play()
        else
            switch.BackgroundColor3 = targetColor
            knob.Position = targetPos
        end
    end

    switch.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isOn = not isOn
            updateVisual(true)
            if onToggle then
                onToggle(isOn)
            end
        end
    end)

    local api = {}
    function api:Set(on, noAnim)
        isOn = on
        updateVisual(not noAnim)
    end
    function api:Get()
        return isOn
    end

    updateVisual(false)
    return api
end

