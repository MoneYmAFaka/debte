-- ENEMY + BATTLEFIELD ANALYSIS (SMART LOGIC)
-- =====================================================

local function GetUnits(isEnemy)
    local units = {}
    local reg = workspace:FindFirstChild("NpcRegistryCamera")
    if not reg then return units end

    local myId = LocalPlayer.UserId
    local playerSide = GetSide()
    local enemySide = GetEnemySide()

    for _, child in ipairs(reg:GetChildren()) do
        local models = {}
        if child:IsA("Folder") then
            for _, m in ipairs(child:GetChildren()) do table.insert(models, m) end
        elseif child:IsA("Model") and child.PrimaryPart then
            table.insert(models, child)
        end

        for _, m in ipairs(models) do
            if m.PrimaryPart then
                local owner = m:GetAttribute("OwnerUserId")
                local sideTag = m:HasTag("SideA") and "SideA" or m:HasTag("SideB") and "SideB" or nil

                local belongsToEnemy = false
                if owner ~= nil then
                    belongsToEnemy = (owner ~= myId)
                else
                    belongsToEnemy = (sideTag == enemySide)
                end

                if (isEnemy and belongsToEnemy) or (not isEnemy and not belongsToEnemy) then
                    local cardName = (m.Name:match("^([%w]+)")) or m.Name
                    table.insert(units, {
                        model = m,
                        pos = m.PrimaryPart.Position,
                        name = cardName,
                        x = m.PrimaryPart.Position.X,
                        z = m.PrimaryPart.Position.Z,
                    })
                end
            end
        end
    end
    return units
end

-- Divide into lanes using X coordinate (approximate)
local function GetLane(x)
    if x < -18 then return "LEFT" end
    if x > 18 then return "RIGHT" end
    return "MID"
end

local function GroupByLane(units)
    local lanes = { LEFT = {}, MID = {}, RIGHT = {} }
    for _, u in ipairs(units) do
        local lane = GetLane(u.x)
        table.insert(lanes[lane], u)
    end
    return lanes
end

-- Calculate pressure: how dangerous enemies are on our side of the map
local function CalculatePressure(enemyUnits)
    local side = GetSide()
    local myHalfSign = (side == "SideA") and -1 or 1
    local pressure = 0
    local lanePressure = { LEFT = 0, MID = 0, RIGHT = 0 }

    for _, u in ipairs(enemyUnits) do
        local lane = GetLane(u.x)
        -- If enemy is on our half of the arena (Z direction)
        if (side == "SideA" and u.z < 10) or (side == "SideB" and u.z > -10) then
            local weight = 1
            local role = GetCardRole(u.name)
            if role == "WINCON" or role == "HEAVY" then weight = 2.5 end
            if role == "SWARM" then weight = 1.3 end

            pressure += weight
            lanePressure[lane] += weight
        end
    end

    return pressure, lanePressure
end

-- Get approximate frontline for friendly units (farthest toward enemy)
local function GetFriendlyFrontline(friendlyUnits, side)
    local bestZ = (side == "SideA") and -999 or 999
    local pos = nil

    for _, u in ipairs(friendlyUnits) do
        if (side == "SideA" and u.z > bestZ) or (side == "SideB" and u.z < bestZ) then
            bestZ = u.z
            pos = u.pos
        end
    end
    return pos
end

-- Find best tile for a card given strategy
local function ChooseSmartTile(cardName, isDefensive, friendlyFront)
    local side = GetSide()
    local tiles = TileHandler:GetValidTiles(side)
    if #tiles == 0 then return nil end

    local info = CardInfo[cardName] or {}
    local role = GetCardRole(cardName)
    local isSpell = role == "SPELL"
    local isBuilding = role == "BUILDING"

    local pushDir = (side == "SideA") and 1 or -1   -- direction toward enemy
    local bestScore = math.huge
    local bestTile = nil

    for _, tile in ipairs(tiles) do
        local p = tile.Position
        local score = math.abs(p.X) * 0.7   -- prefer center-ish

        if friendlyFront then
            -- Support your troops: place slightly in front of frontline
            local frontZ = friendlyFront.Z
            local distToFront = math.abs(p.Z - frontZ)
            if isDefensive then
                score += distToFront * 0.4
            else
                score += distToFront * 0.9   -- still try to stay near action
                score -= (p.Z * pushDir) * 0.6
            end
        else
            if isDefensive then
                score += (p.Z * pushDir) * -0.9   -- stay back
            else
                score -= (p.Z * pushDir) * 1.2   -- push forward
            end
        end

        if isSpell then
            score -= (p.Z * pushDir) * 0.5
        elseif isBuilding then
            score += isDefensive and 6 or 22   -- towers love defensive positions
        end

        -- Random jitter to prevent stacking
        score += math.random() * 5.5

        if score < bestScore then
            bestScore = score
            bestTile = tile
        end
    end

    return bestTile
end

-- =====================================================
-- SMART CARD SELECTION
-- =====================================================

local function GetAffordableCards()
    local list = {}
    for _, name in ipairs(state.deck) do
        if CanAfford(name) then
            table.insert(list, name)
        end
    end
    return list
end

local function PickSmartCard(enemyUnits, pressure, lanePressure, elixir)
    local affordable = GetAffordableCards()
    if #affordable == 0 then return nil end

    -- 1. Hard counters first (very high priority)
    for _, e in ipairs(enemyUnits) do
        local counters = COUNTERS[e.name]
        if counters then
            for _, c in ipairs(counters) do
                for _, aff in ipairs(affordable) do
                    if aff == c then
                        log("Countering", e.name, "with", c)
                        return c
                    end
                end
            end
        end
    end

    -- 2. Spell value - only if cluster detected
    local clustered = false
    for _, lane in pairs(lanePressure) do
        if lane >= CONFIG.SPELL_VALUE_MIN then clustered = true end
    end

    if clustered then
        for _, aff in ipairs(affordable) do
            if GetCardRole(aff) == "SPELL" and (aff == "Fireball" or aff == "Arrows") then
                return aff
            end
        end
    end

    -- 3. Decide push vs defend based on elixir and pressure
    local future = GetElixirIn(3)
    local wantsPush = (elixir >= 6.8 or future >= 8) and pressure < 3.5

    if wantsPush then
        -- Try win conditions / heavy first
        local pushOrder = {"ArmoredGiant", "EliteMarines", "ThunderGod", "FireFist", "SunKing", "Barracks"}
        for _, want in ipairs(pushOrder) do
            for _, aff in ipairs(affordable) do
                if aff == want then
                    state.currentStrategy = "push"
                    state.lastBigPlayTime = os.clock()
                    return aff
                end
            end
        end
    end

    if pressure > 3.2 then
        state.currentStrategy = "defend"
        -- Prefer cheap cycle + swarm when under pressure
        -- BUT also consider placing defensive towers/buildings
        table.sort(affordable, function(a, b)
            return (CardInfo[a] and CardInfo[a].EnergyCost or 99) < (CardInfo[b] and CardInfo[b].EnergyCost or 99)
        end)
        for _, aff in ipairs(affordable) do
            local r = GetCardRole(aff)
            if r == "BUILDING" then
                return aff -- towers are excellent for defense
            end
            if r == "SWARM" or r == "MEDIUM" then
                return aff
            end
        end
    end

    -- Default cycle: play cheapest first
    state.currentStrategy = "cycle"
    table.sort(affordable, function(a, b)
        return (CardInfo[a] and CardInfo[a].EnergyCost or 99) < (CardInfo[b] and CardInfo[b].EnergyCost or 99)
    end)
    return affordable[1]
end

-- =====================================================
-- PLACEMENT
-- =====================================================

local function PerformPlace(cardName)
  if not CanAfford(cardName) then return false end

  local elixir = GetElixir()
  local role = GetCardRole(cardName)

  -- Smart hold: don't dump expensive cards
  if (role == "WINCON" or role == "HEAVY") and elixir < GetCardCost(cardName) + 1.2 then
    return false
  end

  -- Basic enemy scan for "smart" decision (still uses workspace, no modules)
  local enemyCount = 0
  local reg = workspace:FindFirstChild("NpcRegistryCamera")
  if reg then
    for _, d in ipairs(reg:GetDescendants()) do
      if d:IsA("Model") and d.PrimaryPart then
        local owner = d:GetAttribute("OwnerUserId")
        if owner ~= LocalPlayer.UserId then
          enemyCount = enemyCount + 1
        end
      end
    end
  end

  local isDefensive = enemyCount > 3
  local cf = GetSmartCFrame(cardName, isDefensive)

  if Spend(cardName) then
    log("REMOTE-PLACE", cardName, "elixir~", math.floor(elixir*10)/10)
  end

  local pr = getPlaceRemote()
  if pr then
    local ctype = GetCardType(cardName)
    pr:FireServer(ctype, cardName, cf)

    state.lastCardPlaced = cardName
    state.placements = (state.placements or 0) + 1
    state.lastPlaceTime = os.clock()
    return true
  end
  return false
end

-- =====================================================
-- MAIN THINK LOOP (SMART BRAIN)
-- =====================================================

local function Think()
  if not IsInBattle() then return end

  local now = os.clock()
  if now - state.lastPlaceTime < CONFIG.PLACE_COOLDOWN then return end

  local elixir = GetElixir()
  if elixir < 1.8 then return end

  -- Simple pressure from workspace (no modules)
  local enemyCount = 0
  local reg = workspace:FindFirstChild("NpcRegistryCamera")
  if reg then
    for _, d in ipairs(reg:GetDescendants()) do
      if d:IsA("Model") and d.PrimaryPart then
        if d:GetAttribute("OwnerUserId") ~= LocalPlayer.UserId then
          enemyCount += 1
        end
      end
    end
  end

  state.enemyCount = enemyCount
  state.pressure = enemyCount

  -- Pick a card from active deck (set by presets or default)
  local active = state.deck or ARENA1_PRESET
  local chosen = nil
  for _, name in ipairs(active) do
    if CanAfford(name) then
      chosen = name
      break
    end
  end

  if not chosen then return end

  -- Avoid spamming expensive
  local role = GetCardRole(chosen)
  if (role == "WINCON" or role == "HEAVY") and (now - state.lastBigPlayTime < CONFIG.BIG_PLAY_COOLDOWN) then
    if elixir < 7.5 then return end
  end

  if PerformPlace(chosen) then
    if role == "WINCON" or role == "HEAVY" then
      state.lastBigPlayTime = now
    end
  end
end

